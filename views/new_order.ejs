function getElapsedTime(placedAt){if(!placedAt)return null;try{const diff=Date.now()-new Date(placedAt).getTime();if(isNaN(diff))return null;if(diff<60000)return Math.floor(diff/1000)+'s';if(diff<3600000)return Math.floor(diff/60000)+'m';if(diff<86400000)return Math.floor(diff/3600000)+'h';return Math.floor(diff/86400000)+'d'}catch(e){return null}}

function updateActiveDot(autoId,currentRun){document.querySelectorAll('.run-dot-'+autoId).forEach(dot=>{dot.style.transform='scale(1)';dot.style.opacity='0.7'});const activeDot=document.getElementById('dot_'+autoId+'_'+currentRun);if(activeDot){activeDot.style.transform='scale(1.5)';activeDot.style.opacity='1'}}

async function loadAutomations(){const el=document.getElementById('automationsList');el.innerHTML='<div class="text-center py-4"><i class="fas fa-spinner fa-pulse fa-2x"></i><p class="mt-2">Loading...</p></div>';const d=await apiCall('/api/get_package_automations');if(!d){el.innerHTML='<div class="text-center py-4 text-danger">Failed to load. <button class="btn btn-sm btn-outline-primary mt-2" onclick="loadAutomations()">Retry</button></div>';return}if(!d.length){el.innerHTML='<div class="text-center py-5 text-muted"><i class="fas fa-robot" style="font-size:48px;"></i><p class="mt-3">No automations</p></div>';return}window._cachedAutos=d;let h='';d.forEach(a=>{const pr=a.progress_percent||0,st=a.status||'Running',rh=a.runs_history||[],tr=a.total_runs||1,cr=a.current_run||0;let sc='status-running',si='Running';if(st.includes('Completed')){sc='status-completed';si='Completed'}else if(st.includes('Waiting')){sc='status-waiting';si='Waiting'}else if(st.includes('Failed')){sc='status-failed';si='Failed'}const smax=Math.max(tr-1,0),sval=Math.min(Math.max((cr||1)-1,0),smax);const tmHTML=st.includes('Waiting')?'<span class="countdown-timer" id="timer_'+a.id+'"><i class="fas fa-hourglass-half"></i> <span id="timerDisplay_'+a.id+'">--:--</span></span>':'';const vr=cr||1;const rd=rh.find(r=>r.run_number===vr)||rh.find(r=>r.run_number===1)||null;const svcs=rd?.services||[];let sh='';if(svcs.length){sh='<div class="mt-2 p-2 rounded" style="background:rgba(0,0,0,0.03);" id="svc_'+a.id+'">';svcs.forEach(s=>{let ss=(s.api_status||'Pending').toString();let scl='status-pending',si2='⏳';const sl=ss.toLowerCase();if(sl.includes('complete')){scl='status-completed';si2='✅'}else if(sl.includes('process')||sl.includes('progress')){scl='status-processing';si2='🔄'}else if(sl.includes('pending')){scl='status-pending';si2='⏳'}else if(sl.includes('fail')||sl.includes('error')){scl='status-failed';si2='❌'}else if(sl.includes('partial')){scl='status-partial';si2='⚠️'}else if(sl.includes('cancel')||sl.includes('refund')){scl='status-failed';si2='🚫'}const elapsed=getElapsedTime(s.placed_at);sh+='<div class="service-item"><div style="flex:1;"><strong style="font-size:12px;">'+escapeHtml((s.service_name||'Unknown').substring(0,40))+'</strong><span class="text-muted small"> - '+(s.quantity||0)+' units</span>'+(s.order_id?' <span class="order-id" style="font-size:9px;">🆔 '+String(s.order_id).substring(0,10)+'</span>':'')+(elapsed?' <span class="text-muted" style="font-size:9px;"><i class="fas fa-clock"></i> '+elapsed+'</span>':'')+'</div><span class="status-badge '+scl+'" style="font-size:10px;">'+si2+' '+escapeHtml(ss)+'</span></div>'});sh+='</div>'}else{sh='<div class="text-center text-muted py-3" id="svc_'+a.id+'">No data</div>'}const hp=svcs.some(s=>s.order_id&&s.api_status!=='Completed'&&s.api_status!=='Failed'&&s.api_status!=='Cancelled');const cb=hp?`<div id="cs_${a.id}"><button class="btn btn-sm btn-primary mt-2" id="chk_${a.id}_${vr}" onclick="checkRunStatus(${a.id}, ${vr})"><i class="fas fa-sync-alt me-1"></i>Check Run ${vr}</button><span class="cooldown-timer ms-2" id="cd_${a.id}_${vr}"></span></div>`:'';let slHTML='';if(tr>1){slHTML='<div class="slider-container mt-3"><div class="d-flex justify-content-between align-items-center mb-1"><button class="btn btn-sm btn-outline-secondary" onclick="prevRun('+a.id+')" style="font-size:11px;"><i class="fas fa-chevron-left"></i> Prev</button><span id="rd_'+a.id+'" class="small fw-bold"><span class="badge bg-primary me-1" style="font-size:10px;">🔍 Run '+vr+'</span>'+vr+'/'+tr+'</span><button class="btn btn-sm btn-outline-secondary" onclick="nextRun('+a.id+')" style="font-size:11px;">Next <i class="fas fa-chevron-right"></i></button></div><input type="range" id="sl_'+a.id+'" class="timeline-slider" min="0" max="'+smax+'" value="'+sval+'" oninput="sliderChange('+a.id+',this.value)"><div class="d-flex flex-wrap small text-muted mt-1" style="gap:4px;">'+Array.from({length:tr},(_,i)=>{const rn=rh.find(r=>r.run_number===i+1);let dot='⚪';if(rn){if(rn.status==='Completed')dot='✅';else if(rn.status==='Running')dot='🔄';else if(rn.status==='Failed')dot='❌';else if(rn.status==='Partial')dot='⚠️'}if(i+1===cr&&st.includes('Waiting'))dot='⏳';else if(i+1===cr&&!st.includes('Waiting')&&!st.includes('Completed'))dot='🔄';const isActive=(i+1===cr)?' style="transform:scale(1.5);opacity:1;"':' style="transform:scale(1);opacity:0.7;"';return'<span class="run-dot run-dot-'+a.id+'" id="dot_'+a.id+'_'+(i+1)+'" onclick="jumpToRun('+a.id+','+(i+1)+')" title="Run '+(i+1)+' - '+(rn?rn.status||'Pending':'Pending')+'"'+isActive+'>'+dot+'</span>'}).join('')+'</div></div>'}h+='<div class="automation-card"><div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2"><div><strong><i class="fas fa-box me-1"></i>'+escapeHtml(a.package_name||'Package')+'</strong>'+tmHTML+'</div><span class="status-badge '+sc+'">'+si+'</span></div><div class="progress-bar-custom"><div class="progress-fill" style="width:'+pr+'%;background:linear-gradient(90deg,#10b981,#f59e0b,#ef4444);"></div></div><div class="d-flex justify-content-between small mt-1 mb-2"><span>Run '+cr+'/'+tr+'</span><strong>'+Math.round(pr)+'%</strong></div>'+slHTML+sh+cb+(a.link?'<div class="mt-2" style="word-break:break-all;"><a href="'+escapeHtml(a.link)+'" target="_blank" rel="noopener" class="small"><i class="fas fa-link me-1"></i>'+escapeHtml(a.link.substring(0,60))+'...</a></div>':'')+'<div class="d-flex justify-content-between align-items-center mt-3"><small class="text-muted"><i class="fas fa-clock me-1"></i>'+escapeHtml(a.interval_display||'N/A')+' | <i class="fas fa-calendar me-1"></i>'+new Date(a.created_at).toLocaleDateString()+'</small><button class="btn btn-sm btn-danger" onclick="deleteAutomation('+a.id+')"><i class="fas fa-trash me-1"></i>Delete</button></div></div>'});el.innerHTML=h;setTimeout(()=>{d.forEach(a=>{if(a.status&&a.status.includes('Waiting')&&a.next_run_at)startCountdown(a.id,a.next_run_at);const cr=a.current_run||1;if(cr)updateActiveDot(a.id,cr)})},500)}

function sliderChange(id,v){const rn=parseInt(v)+1,tr=window._cachedAutos?.find(a=>a.id===id)?.total_runs||1;document.getElementById('rd_'+id).innerHTML='<span class="badge bg-primary me-1" style="font-size:10px;">🔍 Run '+rn+'</span>'+rn+'/'+tr;showRunData(id,rn);updateActiveDot(id,rn)}
function prevRun(id){const s=document.getElementById('sl_'+id);if(s&&parseInt(s.value)>0){s.value=parseInt(s.value)-1;sliderChange(id,s.value)}}
function nextRun(id){const s=document.getElementById('sl_'+id);if(s&&parseInt(s.value)<parseInt(s.max)){s.value=parseInt(s.value)+1;sliderChange(id,s.value)}}
function jumpToRun(id,rn){const s=document.getElementById('sl_'+id);if(s){s.value=rn-1;sliderChange(id,s.value);updateActiveDot(id,rn)}}
function showRunData(id,rn){const a=window._cachedAutos?.find(x=>x.id===id);if(!a)return;const rh=a.runs_history||[],rd=rh.find(r=>r.run_number===rn),svcs=rd?.services||[];const sd=document.getElementById('svc_'+id);if(sd){if(!svcs.length)sd.innerHTML='<div class="text-center text-muted py-3">⏳ No data for Run '+rn+'</div>';else{let h='';svcs.forEach(s=>{let ss=(s.api_status||'Pending').toString();let sc='status-pending',si='⏳';const sl=ss.toLowerCase();if(sl.includes('complete')){sc='status-completed';si='✅'}else if(sl.includes('process')||sl.includes('progress')){sc='status-processing';si='🔄'}else if(sl.includes('pending')){sc='status-pending';si='⏳'}else if(sl.includes('fail')||sl.includes('error')){sc='status-failed';si='❌'}else if(sl.includes('partial')){sc='status-partial';si='⚠️'}else if(sl.includes('cancel')||sl.includes('refund')){sc='status-failed';si='🚫'}const elapsed=getElapsedTime(s.placed_at);h+='<div class="service-item"><div style="flex:1;"><strong style="font-size:12px;">'+escapeHtml((s.service_name||'Unknown').substring(0,40))+'</strong><span class="text-muted small"> - '+(s.quantity||0)+' units</span>'+(s.order_id?' <span class="order-id" style="font-size:9px;">🆔 '+String(s.order_id).substring(0,10)+'</span>':'')+(elapsed?' <span class="text-muted" style="font-size:9px;"><i class="fas fa-clock"></i> '+elapsed+'</span>':'')+'</div><span class="status-badge '+sc+'" style="font-size:10px;">'+si+' '+escapeHtml(ss)+'</span></div>'});sd.innerHTML=h}}const cd2=document.getElementById('cs_'+id);if(cd2){const hp=svcs.some(s=>s.order_id&&s.api_status!=='Completed'&&s.api_status!=='Failed'&&s.api_status!=='Cancelled');if(hp){cd2.innerHTML='<button class="btn btn-sm btn-primary mt-2" id="chk_'+id+'_'+rn+'" onclick="checkRunStatus('+id+','+rn+')"><i class="fas fa-sync-alt me-1"></i>Check Run '+rn+'</button><span class="cooldown-timer ms-2" id="cd_'+id+'_'+rn+'"></span>';cd2.style.display='block'}else cd2.style.display='none'}}
async function checkRunStatus(id,rn){const btn=document.getElementById('chk_'+id+'_'+rn);const cdSpan=document.getElementById('cd_'+id+'_'+rn);if(btn&&btn.disabled){showToast('⏳ Please wait before checking again');return}if(btn){btn.disabled=true;const originalText=btn.innerHTML;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Checking...';btn.setAttribute('data-original-text',originalText)}showToast('🔄 Checking run status...');const d=await apiCall('/api/check_run_status/'+id+'/'+rn,{method:'POST'});if(d&&d.cooldown){const remaining=d.remaining_seconds||5;showToast(d.message);if(btn&&cdSpan){let timeLeft=remaining;cdSpan.innerHTML='<span class="ms-2 small text-warning">'+timeLeft+'s</span>';const timerInterval=setInterval(()=>{timeLeft--;if(timeLeft<=0){clearInterval(timerInterval);cdSpan.innerHTML='';if(btn){btn.disabled=false;btn.innerHTML=btn.getAttribute('data-original-text')||'<i class="fas fa-sync-alt me-1"></i>Check Run'}}else{cdSpan.innerHTML='<span class="ms-2 small text-warning">'+timeLeft+'s</span>'}},1000)}else if(btn){setTimeout(()=>{if(btn){btn.disabled=false;btn.innerHTML=btn.getAttribute('data-original-text')||'<i class="fas fa-sync-alt me-1"></i>Check Run'}},(remaining||5)*1000)}}else if(d&&d.success){showToast(d.message,4000);await updateSingleRunData(id,rn,d.services);if(btn){setTimeout(()=>{btn.disabled=false;btn.innerHTML=btn.getAttribute('data-original-text')||'<i class="fas fa-sync-alt me-1"></i>Check Run'},2000)}}else{showToast(d?.message||'Error checking status');if(btn){setTimeout(()=>{btn.disabled=false;btn.innerHTML=btn.getAttribute('data-original-text')||'<i class="fas fa-sync-alt me-1"></i>Check Run'},2000)}}}
async function updateSingleRunData(autoId,runNumber,newServicesData){const autoIndex=window._cachedAutos.findIndex(a=>a.id===autoId);if(autoIndex!==-1&&window._cachedAutos[autoIndex].runs_history){const runIndex=window._cachedAutos[autoIndex].runs_history.findIndex(r=>r.run_number===runNumber);if(runIndex!==-1&&newServicesData&&newServicesData.length){const existingRun=window._cachedAutos[autoIndex].runs_history[runIndex];window._cachedAutos[autoIndex].runs_history[runIndex].services=newServicesData.map(s=>{const existing=existingRun?.services?.find(ss=>String(ss.order_id)===String(s.order_id));return{service_name:s.service_name,quantity:s.quantity,api_status:s.api_status,api_remains:s.api_remains,order_id:s.order_id,placed_at:existing?.placed_at||s.placed_at||null}});const allDone=newServicesData.every(s=>s.api_status==='Completed'||s.api_status==='Cancelled'||s.api_status==='Failed');if(allDone&&window._cachedAutos[autoIndex].runs_history[runIndex].status!=='Completed'){window._cachedAutos[autoIndex].runs_history[runIndex].status=newServicesData.every(s=>s.api_status==='Completed')?'Completed':'Partial';window._cachedAutos[autoIndex].runs_history[runIndex].completed_at=new Date().toISOString()}}}const svcContainer=document.getElementById('svc_'+autoId);if(svcContainer&&newServicesData&&newServicesData.length){let h='';newServicesData.forEach(s=>{let ss=(s.api_status||'Pending').toString();let scl='status-pending',si='⏳';const sl=ss.toLowerCase();if(sl.includes('complete')){scl='status-completed';si='✅'}else if(sl.includes('process')||sl.includes('progress')){scl='status-processing';si='🔄'}else if(sl.includes('pending')){scl='status-pending';si='⏳'}else if(sl.includes('fail')||sl.includes('error')){scl='status-failed';si='❌'}else if(sl.includes('partial')){scl='status-partial';si='⚠️'}else if(sl.includes('cancel')||sl.includes('refund')){scl='status-failed';si='🚫'}const elapsed=getElapsedTime(s.placed_at);h+='<div class="service-item"><div style="flex:1;"><strong style="font-size:12px;">'+escapeHtml((s.service_name||'Unknown').substring(0,40))+'</strong><span class="text-muted small"> - '+(s.quantity||0)+' units</span>'+(s.order_id?' <span class="order-id" style="font-size:9px;">🆔 '+String(s.order_id).substring(0,10)+'</span>':'')+(elapsed?' <span class="text-muted" style="font-size:9px;"><i class="fas fa-clock"></i> '+elapsed+'</span>':'')+'</div><span class="status-badge '+scl+'" style="font-size:10px;">'+si+' '+escapeHtml(ss)+'</span></div>'});svcContainer.innerHTML=h}const auto=window._cachedAutos.find(a=>a.id===autoId);if(auto&&auto.total_runs){const sliderContainer=document.querySelector('#sl_'+autoId)?.closest('.slider-container');if(sliderContainer){const rh=auto.runs_history||[];const cr=auto.current_run||1;const st=auto.status||'Running';const tr=auto.total_runs;let dotsHtml='<div class="d-flex justify-content-between small text-muted mt-1">';for(let i=0;i<tr;i++){const runData=rh.find(r=>r.run_number===i+1);let dot='⚪';if(runData){if(runData.status==='Completed')dot='✅';else if(runData.status==='Running')dot='🔄';else if(runData.status==='Failed')dot='❌';else if(runData.status==='Partial')dot='⚠️'}if(i+1===cr&&st.includes('Waiting'))dot='⏳';else if(i+1===cr&&!st.includes('Waiting')&&!st.includes('Completed'))dot='🔄';const isActive2=(i+1===cr)?' style="transform:scale(1.5);opacity:1;"':' style="transform:scale(1);opacity:0.7;"';dotsHtml+='<span class="run-dot run-dot-'+autoId+'" id="dot_'+autoId+'_'+(i+1)+'" onclick="jumpToRun('+autoId+','+(i+1)+')" title="Run '+(i+1)+' - '+(runData?runData.status||'Pending':'Pending')+'"'+isActive2+'>'+dot+'</span>'}dotsHtml+='</div>';const existingDots=sliderContainer.querySelector('.d-flex.justify-content-between.small.text-muted.mt-1');if(existingDots)existingDots.outerHTML=dotsHtml}}}
async function deleteAutomation(id){if(!confirm('Delete this automation?'))return;await apiCall('/api/delete_package_automation/'+id,{method:'DELETE'});await loadAutomations();showToast('Deleted')}
function startCountdown(id,nxt){if(countdownIntervals[id])clearInterval(countdownIntervals[id]);const dsp=document.getElementById('timerDisplay_'+id);if(!dsp)return;function upd(){const nw=Date.now(),tg=new Date(nxt).getTime(),df=tg-nw;if(df<=0){dsp.innerText='Starting...';clearInterval(countdownIntervals[id]);setTimeout(()=>loadAutomations(),5000);return}const h=Math.floor(df/3600000),m=Math.floor((df%3600000)/60000),s=Math.floor((df%60000)/1000);dsp.innerText=h>0?h+'h '+m+'m':m>0?m+'m '+s+'s':s+'s'}upd();countdownIntervals[id]=setInterval(upd,1000)}

// ============ SHARED ============
async function loadSharedPackages(){const el=document.getElementById('sharedPackagesList');el.innerHTML='<div class="text-center py-4"><i class="fas fa-spinner fa-pulse fa-2x"></i><p class="mt-2">Loading shared packages...</p></div>';const d=await apiCall('/api/get_shared_api_settings');if(!d){el.innerHTML='<div class="text-center py-4 text-danger">Failed to load</div>';return}if(!d.length){el.innerHTML='<div class="text-center py-5 text-muted"><i class="fas fa-globe" style="font-size:48px;"></i><p class="mt-3">No shared packages</p></div>';return}let h='';d.forEach(p=>{const isO=p.username===currentUser;const sd=p.service_data||[];const sc=sd.length;const tc=sd.reduce((sm,s)=>sm+((s.service_rate*s.quantity)/1000),0);const bdt=(tc*usdToBdt).toFixed(2);let sp='';if(sd.length>0){sp='<div class="service-preview-box">';sd.forEach(s=>{const c=(((s.service_rate*s.quantity)/1000)*usdToBdt).toFixed(2);sp+='<div class="service-preview-item"><i class="fas fa-chevron-right me-1" style="font-size:8px;"></i><strong>'+escapeHtml((s.service_name||'Unknown').substring(0,30))+'</strong> <span class="text-muted">- '+formatNumber(s.quantity)+' units (BDT '+c+')</span></div>'});sp+='</div>'}h+='<div class="shared-package-card" onclick="importPackage('+p.id+')" style="cursor:pointer;"><div class="d-flex justify-content-between align-items-start"><div style="flex:1;"><div class="d-flex align-items-center gap-2 flex-wrap mb-2"><strong><i class="fas fa-box me-1"></i>'+escapeHtml(p.name)+'</strong>'+(isO?'<span class="badge bg-success"><i class="fas fa-user-check me-1"></i>Your Package</span>':'<span class="badge bg-primary"><i class="fas fa-user me-1"></i>By: '+escapeHtml(p.username)+'</span>')+'</div><div class="text-muted small"><i class="fas fa-layer-group me-1"></i>'+sc+' services | <i class="fas fa-coins me-1"></i>Total: <strong>BDT '+formatNumber(bdt)+'</strong></div>'+(p.description?'<div class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i>'+escapeHtml(p.description.substring(0,150))+'</div>':'')+sp+'<small class="text-muted mt-2 d-block"><i class="fas fa-calendar me-1"></i>Shared: '+new Date(p.created_at).toLocaleDateString()+'</small></div>'+(isO?'<button class="btn btn-sm btn-danger" onclick="event.stopPropagation();deleteSharedPackage('+p.id+')" title="Delete"><i class="fas fa-trash"></i></button>':'')+'</div></div>'});el.innerHTML=h}
async function importPackage(id){if(!confirm('Import this package?'))return;const d=await apiCall('/api/use_shared_api_settings/'+id,{method:'POST'});if(d&&d.success){showToast(d.message);await loadPackage();if(document.getElementById('bulkOrderSection').style.display!=='none')updateBulkCount();document.querySelector('.tab-btn[data-tab="package"]').click()}else showToast(d?.message||'Error')}
async function deleteSharedPackage(id){if(!confirm('Delete this shared package?'))return;await apiCall('/api/delete_my_shared_package/'+id,{method:'DELETE'});await loadSharedPackages();showToast('Deleted')}
function openShareModal(){if(!packageServices.length)return showToast('Package is empty');openModal('shareModal')}
async function publishPackage(){const n=document.getElementById('packageName').value.trim(),d=document.getElementById('packageDescription').value.trim();if(!n)return showToast('Package name required');if(!packageServices.length)return showToast('Package is empty');const r=await apiCall('/api/share_api_settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:n,description:d})});if(r&&r.success){showToast('Published!');closeModal('shareModal');document.getElementById('packageName').value='';document.getElementById('packageDescription').value='';await loadSharedPackages()}else showToast(r?.message||'Error')}

// ============ SEARCH ============
async function searchService(){const id=document.getElementById('searchServiceId').value.trim();if(!id)return showToast('Enter Service ID');const btn=document.getElementById('searchBtn');const origHTML=btn.innerHTML;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Searching...';const rd=document.getElementById('searchResult');rd.style.display='block';rd.innerHTML='<div class="text-center py-3"><i class="fas fa-spinner fa-pulse me-2"></i>Searching service '+escapeHtml(id)+'...</div>';const d=await apiCall('/api/services');await new Promise(r=>setTimeout(r,500));if(!d){rd.innerHTML='<div class="alert alert-danger">Failed to load services</div>';btn.disabled=false;btn.innerHTML=origHTML;return}const s=d.find(x=>String(x.service)===String(id));if(s){const bdt=(s.rate*usdToBdt).toFixed(2);rd.innerHTML='<div class="alert alert-success"><strong><i class="fas fa-check-circle me-1"></i>Service Found!</strong><hr><div><strong>'+escapeHtml(s.name)+'</strong></div><div class="small mt-1"><i class="fas fa-fingerprint me-1"></i>ID: '+s.service+' | <i class="fas fa-coins me-1"></i>BDT '+bdt+'/1k | Min: '+(s.min||100)+' | Max: '+(s.max||10000)+'</div><div class="mt-2"><button class="btn btn-sm btn-success me-1" onclick="addToPackage('+s.service+',\''+escapeJs(s.name)+'\','+s.rate+','+(s.min||100)+','+(s.max||10000)+')"><i class="fas fa-plus me-1"></i>Add to Package</button><button class="btn btn-sm btn-warning" onclick="addToFavorite('+s.service+',\''+escapeJs(s.name)+'\','+s.rate+')"><i class="fas fa-star me-1"></i>Favorite</button></div></div>';setTimeout(()=>rd.style.display='none',20000)}else{rd.innerHTML='<div class="alert alert-danger"><i class="fas fa-times-circle me-1"></i>Service not found with ID: '+escapeHtml(id)+'</div>';setTimeout(()=>rd.style.display='none',4000)}btn.disabled=false;btn.innerHTML=origHTML}

// ============ EVENTS ============
document.addEventListener('DOMContentLoaded',function(){document.querySelectorAll('.platform-btn').forEach(b=>{b.addEventListener('click',function(){document.querySelectorAll('.platform-btn').forEach(x=>x.classList.remove('selected'));this.classList.add('selected');selectedPlatform=this.getAttribute('data-platform');loadServices()})});document.querySelectorAll('.tab-btn').forEach(b=>{b.addEventListener('click',function(){const t=this.getAttribute('data-tab');document.querySelectorAll('.tab-btn').forEach(x=>x.classList.remove('active'));document.querySelectorAll('.tab-content').forEach(x=>x.classList.remove('active'));this.classList.add('active');document.getElementById(t+'Tab').classList.add('active');if(t==='shared')loadSharedPackages();if(t==='automations')loadAutomations()})})});
document.addEventListener('click',function(e){if(!e.target.closest('.dropdown-btn')&&!e.target.closest('.dropdown-menu-custom'))document.querySelectorAll('.dropdown-menu-custom').forEach(m=>{if(m.classList.contains('show'))m.classList.remove('show')})});
document.addEventListener('keydown',function(e){if(e.key==='Escape')document.querySelectorAll('.modal-custom.show').forEach(m=>m.classList.remove('show'))});

async function init(){applyTheme();await loadUserInfo();await loadApiKey();await loadFavorites();await loadPackage();await loadSharedPackages();await loadAutomations();setInterval(async()=>{const at=document.querySelector('.tab-btn.active');if(at&&at.getAttribute('data-tab')==='automations')await loadAutomations()},60000);setTimeout(()=>{if(userApiKey&&!selectedPlatform){const fp=document.querySelector('.platform-btn[data-platform="instagram"]');if(fp)fp.click()}},1500)}
init().catch(console.error);
</script>
</body>
</html>