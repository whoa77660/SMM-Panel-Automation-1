        .btn-success-custom { background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%); border: none; padding: 14px; border-radius: 12px; color: white; font-weight: 700; width: 100%; cursor: pointer; font-size: 15px; transition: all 0.3s; }
