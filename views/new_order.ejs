        .btn-primary-custom { background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); border: none; padding: 14px; border-radius: 12px; color: white; font-weight: 700; width: 100%; margin-top: 10px; cursor: pointer; font-size: 15px; transition: all 0.3s; }
