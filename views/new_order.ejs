            <div class="platform-buttons"><div class="platform-btn" data-platform="instagram"><i class="fab fa-instagram me-2"></i>Instagram</div><div class="platform-btn" data-platform="tiktok"><i class="fab fa-tiktok me-2"></i>TikTok</div></div>
            <div class="section"><div class="section-title mb-2"><i class="fas fa-search me-2"></i>Search Service by ID</div><div class="input-group"><input type="number" id="searchServiceId" class="form-control" placeholder="Enter Service ID..."><button class="btn btn-primary" onclick="searchService()" id="searchBtn"><i class="fas fa-search me-1"></i>Search</button></div><div id="searchResult" class="mt-3" style="display:none;"></div></div>
            <div class="section"><div class="section-title mb-2"><i class="fas fa-star text-warning me-2"></i>My Favorites</div><div id="favoritesList" class="mt-2"></div></div>
            <div class="section" id="categorySection" style="display:none;"><div class="section-title mb-2"><i class="fas fa-folder me-2"></i>Category Filter</div><div class="dropdown-btn" onclick="toggleDropdown('categoryMenu')"><span id="selectedCategoryText">📂 All Categories</span><i class="fas fa-chevron-down"></i></div><div id="categoryMenu" class="dropdown-menu-custom"></div></div>
            <div class="section" id="serviceSection" style="display:none;"><div class="section-title mb-2"><i class="fas fa-list me-2"></i>Available Services</div><div class="dropdown-btn" onclick="toggleDropdown('serviceMenu')"><span id="selectedServiceText">📋 Select a Service</span><i class="fas fa-chevron-down"></i></div><div id="serviceMenu" class="dropdown-menu-custom"></div></div>
            <div class="section"><div class="d-flex justify-content-between align-items-center mb-2"><div class="section-title mb-0"><i class="fas fa-box me-2"></i>Your Package</div><button class="btn btn-sm btn-danger" onclick="clearAllPackage()"><i class="fas fa-trash me-1"></i>Clear All</button></div><div id="packageList" class="mt-2"></div><div class="summary-box mt-3 p-3 rounded"><div class="d-flex justify-content-between"><span><strong><i class="fas fa-layer-group me-1"></i>Services:</strong> <span id="packageCount">0</span></span><span><strong><i class="fas fa-coins me-1"></i>Total Cost:</strong> <span id="packageCost">BDT 0</span></strong></span></div></div></div>
            <div class="section"><div class="section-title mb-2"><i class="fas fa-link me-2"></i>Target Link</div><input type="text" id="targetLink" class="form-control" placeholder="https://www.instagram.com/p/..."><div class="text-muted small mt-1">📌 All services will run on this link</div><div class="mt-3"><div class="d-flex justify-content-between align-items-center mb-2"><div class="section-title mb-0"><i class="fas fa-layer-group me-2"></i>Bulk Order (Multiple Links)</div><button class="btn btn-sm btn-outline-secondary" onclick="toggleBulkOrder()" id="toggleBulkBtn"><i class="fas fa-expand me-1"></i>Show Bulk Links</button></div><div id="bulkOrderSection" style="display:none;"><textarea id="bulkLinks" class="form-control" rows="5" placeholder="Paste multiple links - one per line&#10;Example:&#10;https://www.instagram.com/p/abc/&#10;https://www.instagram.com/p/def/"></textarea><div class="d-flex gap-2 mt-2"><small class="text-muted"><i class="fas fa-info-circle me-1"></i>Total Links: <strong id="bulkLinkCount">0</strong></small><button class="btn btn-sm btn-outline-danger ms-auto" onclick="clearBulkLinks()"><i class="fas fa-trash me-1"></i>Clear</button></div><div id="bulkPreview" class="bulk-summary mt-2" style="display:none;"></div></div></div></div>
            <div class="section"><div class="section-title mb-2"><i class="fas fa-repeat me-2"></i>Number of Runs</div><input type="number" id="repeatCount" class="form-control" value="1" min="1" max="100"></div>
            <div class="section"><div class="section-title mb-2"><i class="fas fa-clock me-2"></i>Interval Between Runs</div><select id="intervalSelect" class="form-select"><option value="30m">30 Minutes</option><option value="1h" selected>1 Hour</option><option value="2h">2 Hours</option><option value="3h">3 Hours</option><option value="6h">6 Hours</option><option value="12h">12 Hours</option><option value="24h">24 Hours</option></select></div>
            <div class="section"><button class="btn-success-custom" onclick="startAutomation()"><i class="fas fa-rocket me-2"></i>START PACKAGE AUTOMATION (Single Link)</button><button class="btn-warning-custom" onclick="startBulkAutomation()"><i class="fas fa-bolt me-2"></i>START BULK AUTOMATION</button><button class="btn-primary-custom" onclick="openShareModal()"><i class="fas fa-share-alt me-2"></i>Publish Package to Community</button></div>
        </div>
        <div class="tab-content" id="sharedTab"><div class="section"><div class="section-title mb-3"><i class="fas fa-globe me-2"></i>Community Shared Packages</div><div id="sharedPackagesList"><div class="text-center py-4 text-muted"><i class="fas fa-spinner fa-pulse me-2"></i>Loading...</div></div></div></div>
        <div class="tab-content" id="automationsTab"><div class="section"><div class="section-title mb-3"><i class="fas fa-cogs me-2"></i>My Active Automations</div><div id="automationsList"><div class="text-center py-4 text-muted"><i class="fas fa-spinner fa-pulse me-2"></i>Loading...</div></div></div></div>
    </div>
</div>

<div id="apiModal" class="modal-custom"><div class="modal-content"><div class="modal-header"><h5 class="mb-0"><i class="fas fa-key me-2"></i>API Key Settings</h5><button type="button" class="btn-close btn-close-white" onclick="closeModal('apiModal')"></button></div><div class="modal-body"><label class="form-label fw-bold mb-2">SMMGen API Key</label><input type="text" id="apiKeyInput" class="form-control" placeholder="Enter your API key"><div class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i>Get your API key from SMMGen dashboard</div></div><div class="modal-footer"><button class="btn btn-secondary" onclick="closeModal('apiModal')">Cancel</button><button class="btn btn-primary" onclick="saveApiKey()"><i class="fas fa-save me-1"></i>Save API Key</button></div></div></div>
<div id="shareModal" class="modal-custom"><div class="modal-content"><div class="modal-header"><h5 class="mb-0"><i class="fas fa-share-alt me-2"></i>Publish Package</h5><button type="button" class="btn-close btn-close-white" onclick="closeModal('shareModal')"></button></div><div class="modal-body"><label class="form-label fw-bold mb-2">Package Name *</label><input type="text" id="packageName" class="form-control" placeholder="e.g., Instagram Growth Pack"><label class="form-label fw-bold mt-3 mb-2">Description (Optional)</label><textarea id="packageDescription" class="form-control" rows="3" placeholder="Describe what this package does..."></textarea></div><div class="modal-footer"><button class="btn btn-secondary" onclick="closeModal('shareModal')">Cancel</button><button class="btn btn-success" onclick="publishPackage()"><i class="fas fa-upload me-1"></i>Publish</button></div></div></div>
<div id="toastMsg" class="toast-msg"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
const usdToBdt = <%- JSON.stringify(usd_to_bdt_rate) %>;
let currentUser='',userApiKey='',selectedPlatform=null,selectedCategory=null,allServices=[],categories=[],favorites=[],packageServices=[],countdownIntervals={},bulkLinks=[];
window._cachedAutos=[];

function escapeHtml(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML}
function escapeJs(s){if(!s)return'';return s.replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/"/g,'\\"').replace(/\n/g,'\\n').replace(/\r/g,'\\r')}
function showToast(m,t=3000){const toast=document.getElementById('toastMsg');toast.innerHTML=m;toast.style.display='block';clearTimeout(toast._t);toast._t=setTimeout(()=>toast.style.display='none',t)}
function openModal(id){document.getElementById(id).classList.add('show')}
function closeModal(id){document.getElementById(id).classList.remove('show')}
function toggleDropdown(id){const m=document.getElementById(id);const o=m.classList.contains('show');document.querySelectorAll('.dropdown-menu-custom').forEach(x=>x.classList.remove('show'));if(!o)m.classList.add('show')}
function formatNumber(n){if(!n&&n!==0)return'0';return Number(n).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}

function applyTheme(){const s=localStorage.getItem('theme')||'dark';if(s==='light'){document.body.classList.remove('dark');document.body.classList.add('light');document.getElementById('themeIcon').className='fas fa-moon'}else{document.body.classList.remove('light');document.body.classList.add('dark');document.getElementById('themeIcon').className='fas fa-sun'}}
function toggleTheme(){if(document.body.classList.contains('dark')){document.body.classList.remove('dark');document.body.classList.add('light');localStorage.setItem('theme','light');document.getElementById('themeIcon').className='fas fa-moon'}else{document.body.classList.remove('light');document.body.classList.add('dark');localStorage.setItem('theme','dark');document.getElementById('themeIcon').className='fas fa-sun'}}

async function apiCall(url,opts={}){try{const r=await fetch(url,opts);if(r.status===401){showToast('Session expired',4000);setTimeout(()=>location.href='/',2000);return null}return await r.json()}catch(e){showToast('Network error',4000);return null}}
async function loadUserInfo(){const d=await apiCall('/api/get_user_info');if(d){currentUser=d.username;document.getElementById('usernameDisplay').innerHTML=d.is_admin?'<i class="fas fa-crown me-1"></i>'+d.username:'<i class="fas fa-user me-1"></i>'+d.username}}
async function loadApiKey(){const d=await apiCall('/api/get_api_key');if(d&&d.api_key){userApiKey=d.api_key;document.getElementById('apiKeyInput').value=userApiKey;loadBalance();if(selectedPlatform)loadServices()}}
async function loadBalance(){if(!userApiKey){document.getElementById('balanceAmount').innerHTML='No API Key';return}const d=await apiCall('/api/balance');if(d&&d.balance!==undefined){document.getElementById('balanceAmount').innerHTML='BDT '+formatNumber(parseFloat(d.balance)*usdToBdt)}else{document.getElementById('balanceAmount').innerHTML='Error loading'}}
async function saveApiKey(){const k=document.getElementById('apiKeyInput').value.trim();if(!k)return showToast('Enter API key');const d=await apiCall('/api/set_api_key',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({api_key:k})});if(d&&d.success){userApiKey=k;showToast('Saved!');closeModal('apiModal');loadBalance();if(selectedPlatform)loadServices()}else showToast(d?.message||'Error')}
function openApiModal(){document.getElementById('apiModal').classList.add('show')}
async function logout(){await fetch('/logout');location.href='/'}

// ============ BULK ORDER ============
function toggleBulkOrder(){const s=document.getElementById('bulkOrderSection');const b=document.getElementById('toggleBulkBtn');if(s.style.display==='none'){s.style.display='block';b.innerHTML='<i class="fas fa-compress me-1"></i>Hide Bulk Links';updateBulkCount()}else{s.style.display='none';b.innerHTML='<i class="fas fa-expand me-1"></i>Show Bulk Links'}}
function updateBulkCount(){const t=document.getElementById('bulkLinks').value.trim();if(!t){bulkLinks=[];document.getElementById('bulkLinkCount').innerHTML='0';document.getElementById('bulkPreview').style.display='none';return}bulkLinks=t.split('\n').map(l=>l.trim()).filter(l=>l&&(l.startsWith('http://')||l.startsWith('https://')));document.getElementById('bulkLinkCount').innerHTML=bulkLinks.length;renderBulkPreview()}
function renderBulkPreview(){const p=document.getElementById('bulkPreview');if(!bulkLinks.length){p.style.display='none';return}p.style.display='block';let h='<strong><i class="fas fa-list me-1"></i>Bulk Links ('+bulkLinks.length+'):</strong><div class="mt-2">';bulkLinks.forEach((l,i)=>{h+='<div class="bulk-link-item"><span style="flex:1;word-break:break-all;"><span class="badge bg-primary me-2">#'+(i+1)+'</span>'+escapeHtml(l.length>70?l.substring(0,70)+'...':l)+'</span><button class="btn btn-sm btn-outline-danger" onclick="removeBulkLink('+i+')"><i class="fas fa-times"></i></button></div>'});h+='</div>';const tc=calculateBulkCost();if(tc>0){h+='<div class="mt-2 p-2 rounded" style="background:rgba(16,185,129,0.1);"><strong><i class="fas fa-coins me-1"></i>Total Estimated Cost: BDT '+formatNumber(tc)+'</strong> ('+bulkLinks.length+' links x '+packageServices.length+' services)</div>'}p.innerHTML=h}
function calculateBulkCost(){if(!packageServices.length||!bulkLinks.length)return 0;return bulkLinks.length*packageServices.reduce((sum,svc)=>sum+((svc.rate*svc.quantity)/1000)*usdToBdt,0)}
function removeBulkLink(i){bulkLinks.splice(i,1);document.getElementById('bulkLinks').value=bulkLinks.join('\n');updateBulkCount();showToast('Link removed',2000)}
function clearBulkLinks(){document.getElementById('bulkLinks').value='';bulkLinks=[];updateBulkCount();showToast('All bulk links cleared',2000)}
document.getElementById('bulkLinks').addEventListener('input',function(){clearTimeout(this._debounce);this._debounce=setTimeout(()=>updateBulkCount(),300)});
async function startBulkAutomation(){if(!packageServices.length)return showToast('Package is empty');updateBulkCount();if(!bulkLinks.length)return showToast('Add bulk links (one per line)');const runs=parseInt(document.getElementById('repeatCount').value)||1;if(runs<1||runs>100)return showToast('Runs: 1-100 allowed');const interval=document.getElementById('intervalSelect').value;const tc=calculateBulkCost();const totalTC=tc*runs;if(!confirm('START BULK ORDER?\n\nLinks: '+bulkLinks.length+'\nServices per link: '+packageServices.length+'\nPer run cost: BDT '+formatNumber(tc)+'\nRuns per link: '+runs+'\nTotal estimated: BDT '+formatNumber(totalTC)+'\nInterval: '+interval+'\n\nThis will create '+bulkLinks.length+' automations'))return;showToast('Creating bulk automations...',0);let successCount=0;let failCount=0;for(let i=0;i<bulkLinks.length;i++){const link=bulkLinks[i];const d=await apiCall('/api/create_package_automation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({package_name:'Bulk_'+(i+1)+'_'+new Date().toISOString().replace(/[:.]/g,'-').substring(0,16),link,total_runs:runs,interval,services:packageServices.map(s=>({id:s.id,name:s.name,quantity:s.quantity,rate:s.rate}))})});if(d&&d.success){successCount++;showToast('Bulk progress: '+successCount+'/'+bulkLinks.length+' created',2000)}else{failCount++;showToast('Failed for link #'+(i+1),3000)}if(i<bulkLinks.length-1)await new Promise(r=>setTimeout(r,1500))}const msg='Bulk Complete: '+successCount+' created'+(failCount>0?', '+failCount+' failed':'')+'. Check Automations tab.';showToast(msg,6000);clearBulkLinks();document.querySelector('.tab-btn[data-tab="automations"]').click();await loadAutomations()}

// ============ SERVICES ============
async function loadServices(){if(!userApiKey||!selectedPlatform){if(!userApiKey)showToast('Set API key first');return}selectedCategory=null;document.getElementById('selectedCategoryText').innerHTML='📂 All Categories';const d=await apiCall('/api/services/filter',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({platform:selectedPlatform})});if(!d||!d.length){showToast('No services found');return}allServices=d.sort((a,b)=>(a.rate||0)-(b.rate||0));
    // After loading live services, refresh the min values stored in favorites
    // so the badge labels show the correct minimum (avoids the stale-100 default).
    let favUpdated=false;
    favorites=favorites.map(f=>{const live=allServices.find(s=>s.service==f.id);if(live&&live.min&&live.min!==(f.min||100)){favUpdated=true;return{...f,min:live.min}}return f});
    if(favUpdated)renderFavorites();
    const cats=new Set();allServices.forEach(s=>{const n=s.name.toLowerCase();if(n.includes('follower'))cats.add('👥 Followers');else if(n.includes('like'))cats.add('❤️ Likes');else if(n.includes('comment'))cats.add('💬 Comments');else if(n.includes('view'))cats.add('👁️ Views');else if(n.includes('share'))cats.add('📤 Shares');else cats.add('📦 Other')});categories=Array.from(cats);renderCategories();renderServices();document.getElementById('categorySection').style.display='block';document.getElementById('serviceSection').style.display='block';showToast('✅ Loaded '+allServices.length+' services')}
function renderCategories(){const m=document.getElementById('categoryMenu');let h='<div class="dropdown-item" onclick="selectCategory(null)" style="font-weight:600;"><i class="fas fa-globe me-2"></i>All Categories</div>';categories.forEach(c=>{h+='<div class="dropdown-item" onclick="selectCategory(\''+escapeJs(c)+'\')">'+c+'</div>'});m.innerHTML=h}
const CATEGORY_KEYWORDS={'👥 Followers':['follower'],'❤️ Likes':['like'],'💬 Comments':['comment'],'👁️ Views':['view'],'📤 Shares':['share'],'📦 Other':[]};
function selectCategory(c){selectedCategory=c;document.getElementById('selectedCategoryText').innerHTML=c||'📂 All Categories';toggleDropdown('categoryMenu');renderServices()}
function renderServices(){let f=allServices;if(selectedCategory){const kw=CATEGORY_KEYWORDS[selectedCategory];if(kw&&kw.length)f=allServices.filter(s=>{const n=s.name.toLowerCase();return kw.some(k=>n.includes(k))})}let h='';if(!f.length)h='<div class="dropdown-item text-center text-muted">📭 No services found</div>';else f.forEach(s=>{const isFav=favorites.some(fv=>fv.id==s.service);const bdt=(s.rate*usdToBdt).toFixed(2);h+='<div class="dropdown-item" onclick="addToPackage('+s.service+',\''+escapeJs(s.name)+'\','+s.rate+','+(s.min||100)+','+(s.max||10000)+')"><div style="display:flex;justify-content:space-between;align-items:center;"><div><strong>'+(isFav?'⭐ ':'')+escapeHtml(s.name.substring(0,55))+'</strong><div class="text-muted small mt-1">ID: '+s.service+' | BDT '+bdt+'/1k | Min: '+(s.min||100)+'</div></div><i class="fas fa-plus-circle ms-2" style="color:#10b981;"></i></div></div>'});document.getElementById('serviceMenu').innerHTML=h}

// ============ FAVORITES ============
async function loadFavorites(){const d=await apiCall('/api/get_favorites');if(d){favorites=d;renderFavorites()}}
function renderFavorites(){const el=document.getElementById('favoritesList');if(!favorites.length){el.innerHTML='<div class="text-muted text-center py-3">No favorites yet</div>';return}let h='<div class="d-flex flex-wrap gap-2">';favorites.forEach(f=>{const bdt=(f.rate*usdToBdt).toFixed(2);const minQty=f.min||100;h+='<span class="badge bg-warning text-dark p-2" style="cursor:pointer;font-size:12px;" onclick="addFromFavorite('+f.id+',\''+escapeJs(f.name)+'\','+f.rate+','+minQty+')">* '+escapeHtml(f.name.substring(0,30))+' (Min:'+minQty+' | BDT '+bdt+') <i class="fas fa-times-circle ms-1" onclick="event.stopPropagation();removeFavorite('+f.id+')"></i></span>'});h+='</div>';el.innerHTML=h}
async function addFromFavorite(id,name,rate,minQty){
    // Always fetch real min/max from server (servicesCache covers all platforms).
    // allServices only holds the currently-selected platform so it can't be trusted
    // for favourites added from other platforms or before services were loaded.
    let realMin=minQty,realMax=100000;
    try{const info=await apiCall('/api/services/info/'+id);if(info&&info.found){realMin=info.min||minQty;realMax=info.max||100000;}}catch(e){}
    const q=prompt('Add to Package:\n\n'+name+'\n\nMinimum: '+realMin+'\nQuantity:',realMin);
    if(!q)return;
    const qt=parseInt(q);
    if(isNaN(qt)||qt<realMin)return showToast('Minimum '+realMin);
    await addToPackage(id,name,rate,realMin,realMax,qt)
}
async function removeFavorite(id){await apiCall('/api/remove_favorite',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({service_id:id})});await loadFavorites();showToast('Removed from favorites')}
async function addToFavorite(id,name,rate){const serviceInfo=allServices.find(s=>s.service==id);const minQty=serviceInfo?(serviceInfo.min||100):100;const d=await apiCall('/api/add_favorite',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({service_id:id,service_name:name,service_rate:rate,min_quantity:minQty})});if(d&&d.success){await loadFavorites();showToast('Added to favorites!')}else showToast(d?.message||'Error')}

// ============ PACKAGE ============
async function loadPackage(){const d=await apiCall('/api/get_package');if(d){packageServices=d.map(s=>({...s,min:s.min||100,id:Number(s.id)}));renderPackage()}}
async function addToPackage(id,name,rate,min,max,pq=null){let q=pq;if(!q){const inp=prompt('Add to Package:\n\n'+name+'\nMin: '+min+' | Max: '+max+'\n\nQuantity:',min);if(!inp)return;q=parseInt(inp)}if(isNaN(q)||q<min)return showToast('Minimum: '+min);if(q>max)return showToast('Maximum: '+max);const d=await apiCall('/api/add_to_package',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({service_id:id,service_name:name,service_rate:rate,quantity:q})});if(d&&d.success){await loadPackage();showToast('Added to package!');toggleDropdown('serviceMenu');if(document.getElementById('bulkOrderSection').style.display!=='none')updateBulkCount()}else showToast(d?.message||'Error')}
async function removeFromPackage(sid){const d=await apiCall('/api/remove_from_package',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({service_id:sid})});if(d&&d.success){packageServices=packageServices.filter(p=>Number(p.id)!==Number(sid));renderPackage();if(document.getElementById('bulkOrderSection').style.display!=='none')updateBulkCount();showToast('Removed from package')}}
async function editPackageQuantity(serviceId,currentQty,minQty){const pkg=packageServices.find(p=>Number(p.id)===Number(serviceId));if(!pkg)return;const newQty=prompt('Edit Quantity:\n\n'+pkg.name+'\n\nCurrent: '+currentQty+'\nMinimum: '+minQty+'\n\nNew Quantity:',currentQty);if(!newQty)return;const qt=parseInt(newQty);if(isNaN(qt)||qt<minQty){showToast('Minimum quantity is '+minQty);return}const d=await apiCall('/api/update_package_quantity',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({service_id:serviceId,quantity:qt})});if(d&&d.success){await loadPackage();if(document.getElementById('bulkOrderSection').style.display!=='none')updateBulkCount();showToast('Quantity updated!')}else{showToast(d?.message||'Update failed')}}
async function clearAllPackage(){if(!confirm('Clear entire package?'))return;await apiCall('/api/clear_package',{method:'DELETE'});await loadPackage();if(document.getElementById('bulkOrderSection').style.display!=='none')updateBulkCount();showToast('Package cleared')}
function calculateEngagement(svcs){if(!svcs||svcs.length===0)return null;let tv=0,tl=0,tc=0,ts=0;svcs.forEach(s=>{const n=(s.name||'').toLowerCase();const q=s.quantity||0;if(n.includes('view')||n.includes('impression')||n.includes('play'))tv+=q;else if(n.includes('like'))tl+=q;else if(n.includes('comment'))tc+=q;else if(n.includes('share')||n.includes('repost'))ts+=q});const ti=tl+(tc*2)+ts;let er=0;if(tv>0)er=Math.min((ti/tv)*100,100);else if(ti>0)er=Math.min(ti/100,100);let l='',lc='';if(er>=10){l='Excellent';lc='#10b981'}else if(er>=5){l='Good';lc='#f59e0b'}else if(er>=2){l='Average';lc='#f97316'}else if(er>=1){l='Low';lc='#ef4444'}else{l='Poor';lc='#ef4444'}return{rate:Math.round(er*10)/10,level:l,levelColor:lc,views:tv,likes:tl,comments:tc,shares:ts}}
function updateEngagement(){const old=document.getElementById('engagementBox');if(old)old.remove();if(!packageServices.length)return;const eng=calculateEngagement(packageServices);if(!eng)return;const engHTML='<div class="engagement-box mt-3" id="engagementBox"><div class="d-flex align-items-center gap-2 mb-2"><i class="fas fa-chart-line"></i><strong>Expected Engagement:</strong><strong style="color:'+eng.levelColor+';">'+eng.rate+'% - '+eng.level+'</strong></div><div class="engagement-bar"><div class="engagement-fill" style="width:'+eng.rate+'%;background:linear-gradient(90deg,#10b981,#f59e0b,#f97316,#ef4444);"></div></div><div class="engagement-stats"><div class="engagement-stat"><i class="fas fa-eye" style="color:#6366f1;"></i> Views: <strong>'+formatNumber(eng.views)+'</strong></div><div class="engagement-stat"><i class="fas fa-heart" style="color:#ef4444;"></i> Likes: <strong>'+formatNumber(eng.likes)+'</strong></div><div class="engagement-stat"><i class="fas fa-comment" style="color:#10b981;"></i> Comments: <strong>'+formatNumber(eng.comments)+'</strong></div><div class="engagement-stat"><i class="fas fa-share" style="color:#f59e0b;"></i> Shares: <strong>'+formatNumber(eng.shares)+'</strong></div></div></div>';const pl=document.getElementById('packageList');if(pl)pl.insertAdjacentHTML('afterend',engHTML)}
function renderPackage(){const el=document.getElementById('packageList');if(!packageServices.length){el.innerHTML='<div class="text-muted text-center py-4"><i class="fas fa-box-open" style="font-size:24px;"></i><p class="mt-2">Package is empty</p></div>';document.getElementById('packageCount').innerHTML='0';document.getElementById('packageCost').innerHTML='BDT 0';updateEngagement();return}let tc=0,h='';packageServices.forEach((svc,i)=>{const c=((svc.rate*svc.quantity)/1000)*usdToBdt;tc+=c;const minQty=svc.min||100;h+='<div class="package-item" id="pkg_item_'+svc.id+'"><div style="flex:1;margin-right:10px;"><div class="d-flex align-items-center gap-2 mb-1"><span class="badge bg-primary" style="font-size:10px;">#'+(i+1)+'</span><strong style="font-size:13px;">'+escapeHtml(svc.name.substring(0,50))+'</strong></div><div class="text-muted small"><span id="qty_display_'+svc.id+'">'+formatNumber(svc.quantity)+'</span> units x BDT '+((svc.rate*usdToBdt)/1000).toFixed(4)+' = <strong>BDT '+formatNumber(c)+'</strong>'+(minQty?'<br><span class="text-muted" style="font-size:10px;">Min: '+minQty+'</span>':'')+'</div></div><div class="d-flex gap-2"><button class="btn btn-sm btn-warning" onclick="editPackageQuantity('+svc.id+','+svc.quantity+','+minQty+')" style="padding:6px 12px;font-size:11px;"><i class="fas fa-edit me-1"></i>Edit</button><button class="btn btn-sm btn-danger" onclick="removeFromPackage('+svc.id+')" style="padding:6px 12px;font-size:11px;"><i class="fas fa-trash me-1"></i>Remove</button></div></div>'});el.innerHTML=h;document.getElementById('packageCount').innerHTML=packageServices.length;document.getElementById('packageCost').innerHTML='BDT '+formatNumber(tc);updateEngagement()}

