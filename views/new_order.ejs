async function startAutomation(){if(!packageServices.length)return showToast('Package is empty');const link=document.getElementById('targetLink').value.trim();if(!link)return showToast('Enter target link');if(!link.startsWith('http'))return showToast('Link must start with http');const runs=parseInt(document.getElementById('repeatCount').value)||1;if(runs<1||runs>100)return showToast('Runs: 1-100 allowed');const interval=document.getElementById('intervalSelect').value;let sl='';packageServices.forEach((svc,i)=>{sl+='  '+(i+1)+'. '+svc.name.substring(0,40)+' - '+svc.quantity+' units\n'});const tc=packageServices.reduce((sm,svc)=>sm+((svc.rate*svc.quantity)/1000)*usdToBdt,0);if(!confirm('START?\n\nLink: '+link+'\n\nServices:\n'+sl+'\nPer run: BDT '+formatNumber(tc)+'\nRuns: '+runs+'\nTotal: BDT '+formatNumber(tc*runs)+'\nInterval: '+interval))return;const d=await apiCall('/api/create_package_automation',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({package_name:'Pkg_'+new Date().toISOString().replace(/[:.]/g,'-').substring(0,16),link,total_runs:runs,interval,services:packageServices.map(s=>({id:s.id,name:s.name,quantity:s.quantity,rate:s.rate}))})});if(d&&d.success){showToast('Started!',5000);document.getElementById('targetLink').value='';if(confirm('Clear package after starting?'))await clearAllPackage();document.querySelector('.tab-btn[data-tab="automations"]').click();await loadAutomations()}else showToast(d?.message||'Error')}

